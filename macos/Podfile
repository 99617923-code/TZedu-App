# 途正英语 macOS Podfile
# 火鹰科技出品
#
# flutter_sound 仅在 iOS/Android 上使用（录音功能），macOS 不需要。
# macOS 上语音播放由 audioplayers 提供。
# flutter_sound 包的 macOS podspec 有 bug（文件名和 spec.name 不匹配），
# 因此在 macOS 上直接跳过该插件。

platform :osx, '10.15'

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

# ═══════════════════════════════════════════════════════════
# macOS 上需要跳过的插件列表
# flutter_sound 的 macOS podspec 有 bug，且 macOS 不需要录音功能
# ═══════════════════════════════════════════════════════════
MACOS_SKIP_PLUGINS = ['flutter_sound']

# 自定义 pod 安装方法：基于 Flutter 官方 flutter_install_plugin_pods，
# 但跳过 MACOS_SKIP_PLUGINS 中列出的插件
def flutter_install_macos_pods_excluding(application_path)
  application_path ||= File.dirname(defined_in_file.realpath) if respond_to?(:defined_in_file)
  raise 'Could not find application path' unless application_path

  symlink_dir = File.expand_path(File.join('Flutter', 'ephemeral', '.symlinks'), application_path)
  system('rm', '-rf', symlink_dir)
  symlink_plugins_dir = File.expand_path('plugins', symlink_dir)
  system('mkdir', '-p', symlink_plugins_dir)

  plugins_file = File.join(application_path, '..', '.flutter-plugins-dependencies')
  dependencies_hash = flutter_parse_plugins_file(plugins_file)
  plugin_pods = flutter_get_plugins_list(dependencies_hash, 'macos')

  plugin_pods.each do |plugin_hash|
    plugin_name = plugin_hash['name']
    plugin_path = plugin_hash['path']
    has_native_build = plugin_hash.fetch('native_build', true)
    shared_darwin_source = plugin_hash.fetch('shared_darwin_source', false)
    platform_directory = shared_darwin_source ? 'darwin' : 'macos'

    next unless plugin_name && plugin_path && has_native_build

    # 跳过不需要的插件
    if MACOS_SKIP_PLUGINS.include?(plugin_name)
      puts "[TZ] ⏭️  跳过 macOS 插件: #{plugin_name}（不需要）"
      next
    end

    symlink = File.join(symlink_plugins_dir, plugin_name)
    File.symlink(plugin_path, symlink)

    relative = flutter_relative_path_from_podfile(symlink)
    pod plugin_name, path: File.join(relative, platform_directory)
  end

  # FlutterMacOS pod
  pod 'FlutterMacOS', path: File.join('Flutter', 'ephemeral')
end

# ═══════════════════════════════════════════════════════════
# 自动安装 nim_core_v2 所需的 Python requests 模块
# ═══════════════════════════════════════════════════════════
pre_install do |installer|
  puts "[TZ] 检查 Python requests 模块..."
  result = system('python3 -c "import requests" 2>/dev/null')
  unless result
    puts "[TZ] 正在自动安装 Python requests 模块..."
    system('pip3 install requests --quiet') || system('python3 -m pip install requests --quiet')
    puts "[TZ] Python requests 模块安装完成"
  else
    puts "[TZ] Python requests 模块已存在"
  end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # 使用自定义方法安装 pods，跳过 flutter_sound
  flutter_install_macos_pods_excluding(File.dirname(File.realpath(__FILE__)))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)

    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '10.15'
    end
  end
end
