# 途正英语 macOS Podfile
# 火鹰科技出品
#
# nim_core_v2 的 build 脚本依赖 Python requests 模块下载原生 SDK，
# pre_install hook 会自动检测并安装，开发者无需手动操作。
#
# flutter_sound 仅在 iOS/Android 上使用（录音功能），macOS 上语音播放
# 由 audioplayers 提供。flutter_sound 的 macOS podspec 文件名和 spec.name
# 均为 taudio（与包名 flutter_sound 不一致），需要生成正确的 podspec 修复。

platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

# ═══════════════════════════════════════════════════════════
# 修复 flutter_sound macOS podspec 问题
# ═══════════════════════════════════════════════════════════
# flutter_sound 包的 macOS podspec 文件名为 taudio.podspec，且内部
# spec.name = 'taudio'，但 Flutter 插件系统期望 spec.name = 'flutter_sound'。
# 此方法在 flutter_install_all_macos_pods 之后调用，生成一个 name 正确的
# flutter_sound.podspec 文件，CocoaPods 分析依赖时即可正确匹配。
def fix_flutter_sound_podspec_macos(application_path)
  symlink_plugins_dir = File.expand_path(File.join('Flutter', 'ephemeral', '.symlinks', 'plugins'), application_path)
  flutter_sound_macos = File.join(symlink_plugins_dir, 'flutter_sound', 'macos')
  return unless Dir.exist?(flutter_sound_macos)

  flutter_sound_podspec = File.join(flutter_sound_macos, 'flutter_sound.podspec')

  # 每次都重新生成，确保内容正确
  podspec_content = <<~PODSPEC
    Pod::Spec.new do |s|
      s.name             = 'flutter_sound'
      s.version          = '9.30.0'
      s.summary          = 'Flutter Sound - audio playback and recording plugin'
      s.description      = 'A complete api for audio playback and recording.'
      s.homepage         = 'https://github.com/canardoux/flutter_sound'
      s.license          = { :file => '../LICENSE' }
      s.author           = { 'canardoux' => 'canardoux@gmail.com' }
      s.source           = { :path => '.' }
      s.source_files     = 'Classes/**/*'
      s.dependency 'FlutterMacOS'
      s.platform         = :osx, '10.11'
      s.pod_target_xcconfig = { 'DEFINES_MODULE' => 'YES' }
      s.swift_version    = '5.0'
    end
  PODSPEC

  File.write(flutter_sound_podspec, podspec_content)
  puts "[TZ] ✅ 已生成 flutter_sound.podspec（修复 spec.name: taudio -> flutter_sound）"
end

# ═══════════════════════════════════════════════════════════
# 自动安装 nim_core_v2 所需的 Python requests 模块
# ═══════════════════════════════════════════════════════════
pre_install do |installer|
  puts "[TZ] 检查 Python requests 模块..."
  result = system('python3 -c "import requests" 2>/dev/null')
  unless result
    puts "[TZ] 正在自动安装 Python requests 模块..."
    system('pip3 install requests --quiet') || system('python3 -m pip install requests --quiet')
    puts "[TZ] Python requests 模块安装完成"
  else
    puts "[TZ] Python requests 模块已存在"
  end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))

  # 在 flutter_install_all_macos_pods 之后修复 podspec，
  # CocoaPods 的 Analyzing dependencies 在 Podfile 解析完成后才执行。
  fix_flutter_sound_podspec_macos(File.dirname(File.realpath(__FILE__)))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)

    # 确保最低部署版本一致
    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '10.15'
    end
  end
end
