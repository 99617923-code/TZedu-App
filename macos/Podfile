# 途正英语 macOS Podfile
# 火鹰科技出品
#
# nim_core_v2 的 build 脚本依赖 Python requests 模块下载原生 SDK，
# pre_install hook 会自动检测并安装，开发者无需手动操作。

platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

# ═══════════════════════════════════════════════════════════
# 自动安装 nim_core_v2 所需的 Python requests 模块
# 自动修复 flutter_sound 的 podspec 文件名问题
# ═══════════════════════════════════════════════════════════
pre_install do |installer|
  # 检测并安装 Python requests 模块（nim_core_v2 build 脚本需要）
  puts "[TZ] 检查 Python requests 模块..."
  result = system('python3 -c "import requests" 2>/dev/null')
  unless result
    puts "[TZ] 正在自动安装 Python requests 模块..."
    system('pip3 install requests --quiet') || system('python3 -m pip install requests --quiet')
    puts "[TZ] Python requests 模块安装完成"
  else
    puts "[TZ] Python requests 模块已存在"
  end

  # 修复 flutter_sound macOS podspec 文件名不匹配问题
  # flutter_sound 包的 macOS podspec 文件名为 taudio.podspec，
  # 但 Flutter 插件系统期望找到 flutter_sound.podspec，导致 pod install 失败。
  # 这里自动创建一个符号链接来修复。
  symlink_dir = File.expand_path(File.join('Flutter', 'ephemeral', '.symlinks', 'plugins', 'flutter_sound', 'macos'), File.dirname(__FILE__))
  if Dir.exist?(symlink_dir)
    taudio_podspec = File.join(symlink_dir, 'taudio.podspec')
    flutter_sound_podspec = File.join(symlink_dir, 'flutter_sound.podspec')
    if File.exist?(taudio_podspec) && !File.exist?(flutter_sound_podspec)
      puts "[TZ] 修复 flutter_sound macOS podspec: 创建 flutter_sound.podspec -> taudio.podspec"
      File.symlink(taudio_podspec, flutter_sound_podspec)
      puts "[TZ] ✅ flutter_sound macOS podspec 修复完成"
    else
      puts "[TZ] flutter_sound macOS podspec 无需修复"
    end
  end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)

    # 确保最低部署版本一致
    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '10.15'
    end
  end
end
