# 途正英语 macOS Podfile
# 火鹰科技出品
#
# nim_core_v2 的 build 脚本依赖 Python requests 模块下载原生 SDK，
# pre_install hook 会自动检测并安装，开发者无需手动操作。
#
# flutter_sound 仅在 iOS/Android 上使用（录音功能），macOS 不需要。
# macOS 上语音播放由 audioplayers 提供，完全独立于 flutter_sound。

platform :osx, '10.15'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'ephemeral', 'Flutter-Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Flutter-Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_macos_podfile_setup

# ═══════════════════════════════════════════════════════════
# 排除 macOS 不需要的插件（在 Analyzing dependencies 之前执行）
# ═══════════════════════════════════════════════════════════
# flutter_sound 的 macOS podspec 文件名为 taudio.podspec（与包名不一致），
# 导致 CocoaPods 报错 No podspec found for flutter_sound。
# 且 macOS 上只需要 audioplayers 做语音播放，不需要 flutter_sound 录音。
# 在顶层代码中删除 symlink，确保在 CocoaPods 分析依赖之前执行。
require 'fileutils'
flutter_sound_symlink = File.expand_path(File.join('Flutter', 'ephemeral', '.symlinks', 'plugins', 'flutter_sound'), File.dirname(__FILE__))
if File.exist?(flutter_sound_symlink) || File.symlink?(flutter_sound_symlink)
  FileUtils.rm_rf(flutter_sound_symlink)
  puts "[TZ] ✅ 已排除 flutter_sound 插件（macOS 不需要录音功能）"
end

# ═══════════════════════════════════════════════════════════
# 自动安装 nim_core_v2 所需的 Python requests 模块
# ═══════════════════════════════════════════════════════════
pre_install do |installer|
  puts "[TZ] 检查 Python requests 模块..."
  result = system('python3 -c "import requests" 2>/dev/null')
  unless result
    puts "[TZ] 正在自动安装 Python requests 模块..."
    system('pip3 install requests --quiet') || system('python3 -m pip install requests --quiet')
    puts "[TZ] Python requests 模块安装完成"
  else
    puts "[TZ] Python requests 模块已存在"
  end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_macos_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_macos_build_settings(target)

    # 确保最低部署版本一致
    target.build_configurations.each do |config|
      config.build_settings['MACOSX_DEPLOYMENT_TARGET'] = '10.15'
    end
  end
end
